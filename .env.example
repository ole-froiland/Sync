# ─────────────────────────────────────────────────────────────
# Sync – Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file containing real secrets.
# ─────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your_anon_key

# ── Site URL ──────────────────────────────────────────────────
# Used as the base for OAuth redirect URIs.
# Production: set this to your real domain (e.g. https://sync.example.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── GitHub OAuth App (repository connect) ────────────────────
# Separate OAuth App used ONLY for the per-user GitHub repo connection.
# (Supabase login uses its own GitHub OAuth app configured in the Supabase dashboard.)
#
# Create at: GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
#
# Homepage URL:                  https://froiland.netlify.app
# Authorization callback URL:    https://froiland.netlify.app/api/github/callback
#
# Required scope: repo
GITHUB_CONNECT_CLIENT_ID=Ov23li...
GITHUB_CONNECT_CLIENT_SECRET=your_github_connect_client_secret

# ── GitHub Personal Access Token (optional) ──────────────────
# Used only as a fallback when Supabase is not configured (mock/dev mode).
# Per-user OAuth tokens (stored in github_connections) take priority in production.
# Scopes needed: repo  (or public_repo for public repos only)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...your_personal_access_token
